{
  "name": "eureka/eureka-appplication-backoffice",
  "description": "Backoffice Application Eureka Framework - Template App",
  "minimum-stability": "stable",
  "type": "project",
  "license": "MIT",

  "authors": [
    {
      "name": "Romain Cottard",
      "role": "Developer"
    }
  ],

  "autoload": {
    "psr-4": {
      "Application\\": "./src",
      "Application\\Script\\": "./scripts"
    }
  },

  "autoload-dev": {
    "psr-4": {
      "Application\\Tests\\Unit\\": "./tests/unit",
      "Application\\Tests\\Integration\\": "./tests/integration"
    }
  },

  "config": {
    "sort-packages": true
  },

  "require": {
    "php": "8.3.*||8.4.*",
    "ext-json": "*",
    "eureka/component-console": "^6.2.0",
    "eureka/component-database": "^3.3.0",
    "eureka/component-deployer": "^3.0.0",
    "eureka/component-orm": "^6.0.3",
    "eureka/component-password": "^5.0.0",
    "eureka/component-validation": "^5.3.0",
    "eureka/component-web": "^6.0.0",
    "eureka/kernel-console": "^6.1.0",
    "eureka/kernel-http": "^6.0.0",
    "lcobucci/clock": "^3.3.1",
    "lcobucci/jwt": "^5.5.0",
    "nyholm/psr7": "^1.8.2",
    "psr/cache": "^3.0.0",
    "psr/clock": "^1.0.0",
    "psr/container": "^2.0.2",
    "psr/http-message": "^2.0.0",
    "psr/http-server-handler": "^1.0.2",
    "psr/http-server-middleware": "^1.0.2",
    "psr/log": "^3.0.2",
    "symfony/asset-mapper": "^7.2.5",
    "symfony/console": "^7.2.6",
    "symfony/cache": "^7.2.6",
    "symfony/finder": "^7.2.2",
    "symfony/routing": "^7.2.3",
    "twig/twig": "^3.21.1"
  },

  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.75.0",
    "phpstan/phpstan": "^2.1.14",
    "phpstan/phpstan-phpunit": "^2.0.6",
    "phpunit/phpcov": "^11.0",
    "phpunit/phpunit": "^12.1.4",
    "shipmonk/composer-dependency-analyser": "^1.8.2"
  }
}
