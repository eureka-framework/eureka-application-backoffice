{
  "name": "eureka/eureka-appplication-backoffice",
  "description": "Backoffice Application Eureka Framework - Template App",
  "minimum-stability": "stable",
  "type": "project",
  "license": "MIT",

  "authors": [
    {
      "name": "Romain Cottard",
      "role": "Developer"
    }
  ],

  "autoload": {
    "psr-4": {
      "Application\\": "./src",
      "Application\\Script\\": "./scripts"
    }
  },

  "autoload-dev": {
    "psr-4": {
      "Application\\Tests\\": "./tests"
    }
  },

  "config": {
    "sort-packages": true
  },

  "require": {
    "php": "8.4.*",
    "ext-json": "*",
    "eureka/component-console": "^7.0.0",
    "eureka/component-database": "^4.0.0",
    "eureka/component-deployer": "^4.0.0",
    "eureka/component-orm": "^7.2.1",
    "eureka/component-password": "^6.0.0",
    "eureka/component-validation": "^6.2.0",
    "eureka/component-web": "^7.1.0",
    "eureka/kernel-console": "^7.0.0",
    "eureka/kernel-http": "^7.0.0",
    "lcobucci/clock": "^3.5.0",
    "lcobucci/jwt": "^5.6.0",
    "nyholm/psr7": "^1.8.2",
    "psr/cache": "^3.0.0",
    "psr/clock": "^1.0.0",
    "psr/container": "^2.0.2",
    "psr/http-message": "^2.0.0",
    "psr/http-server-handler": "^1.0.2",
    "psr/http-server-middleware": "^1.0.2",
    "psr/log": "^3.0.2",
    "symfony/asset-mapper": "^8.0.8",
    "symfony/console": "^8.0.8",
    "symfony/cache": "^8.0.8",
    "symfony/finder": "^7.4.8",
    "symfony/routing": "^8.0.8",
    "twig/twig": "^3.24.0"
  },

  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.94.2",
    "phpstan/phpstan": "^2.1.46",
    "phpstan/phpstan-deprecation-rules": "^2.0.4",
    "phpstan/phpstan-phpunit": "^2.0.16",
    "phpstan/phpstan-strict-rules": "^2.0.10",
    "phpunit/phpcov": "^13.0.0",
    "phpunit/phpunit": "^13.1.1",
    "shipmonk/composer-dependency-analyser": "^1.8.4"
  }
}
